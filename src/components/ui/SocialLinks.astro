---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<a
  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg
    border border-black/10 dark:border-white/15 text-sm text-gray-600 dark:text-gray-400
    hover:border-black/20 dark:hover:border-white/25 hover:text-gray-900 dark:hover:text-gray-200
    hover:bg-black/5 dark:hover:bg-white/5
    transition-all duration-200"
  href={href}
>
  <slot />
</a>
